{
  "name": "cli-to-mcp",
  "version": "0.1.0",
  "description": "Expose CLI commands as MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cli-to-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "command-line",
    "wrapper",
    "claude",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbgso/mcp-servers.git",
    "directory": "packages/cli-to-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "mcp-shared": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
